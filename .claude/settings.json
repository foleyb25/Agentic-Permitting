{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(uv publish *)",
      "Bash(twine upload *)",
      "Bash(python -m build *)",
      "Edit(./.github/**)",
      "Edit(./.mcp.json)",
      "Edit(./uv.lock)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-access.py\"; if [ -f \"$HOOK\" ]; then python3 \"$HOOK\"; else exit 0; fi"
          }
        ]
      }
    ]
  }
}
