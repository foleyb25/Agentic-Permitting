# Copy to .env (gitignored) and fill in real values.
# .mcp.json reads these via ${VAR} expansion — no secrets are committed.

# Required. Connection string for the project Postgres/Supabase instance.
# ${PERMIT_DATABASE_URL} is referenced in .mcp.json; if unset, the server fails to start.
PERMIT_DATABASE_URL=postgresql://user:password@localhost:5432/permits

# Optional. Statement timeout in ms. .mcp.json defaults this to 5000 if unset
# via ${PG_TIMEOUT_MS:-5000}.
# PG_TIMEOUT_MS=5000
